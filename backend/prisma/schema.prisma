// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  // URL yahan se hata di gayi hai, ye prisma.config.ts mein jayegi
}

model User {
  id                 String   @id @default(uuid())
  name               String
  email              String   @unique
  phone              String?  @unique
  password           String?
  role               Role     @default(CUSTOMER)
  verifyOtp          String?
  verifyOtpExpiryAt  Float?
  isAccountVerified  Boolean  @default(false)
  phoneVerifyOtp     String?
  phoneVerifyOtpExpiryAt Float?
  isPhoneVerified    Boolean  @default(false)
  resetOtp           String?
  resetOtpExpiryAt   Float?
  products           Product[]
  bookings           ServiceBooking[]
  orders             ProductOrder[]
  sellRequests       SellRequest[]
  createdAt          DateTime @default(now())
}

model Product {
  id             String        @id @default(uuid())
  title          String
  description    String
  price          Float
  isUsed         Boolean       @default(false)
  productType    ProductType   @default(NEW)
  conditionScore Int?
  ageMonths      Int?
  warrantyType   WarrantyType?
  warrantyExpiry DateTime?
  warrantyCertificateUrl String?
  stockQty       Int           @default(1)
  isDeleted      Boolean       @default(false)
  serialNumber   String?       @unique
  images         String[]
  status         ProductStatus @default(AVAILABLE)
  sellerId       String
  seller         User          @relation(fields: [sellerId], references: [id])
  orders         ProductOrder[]
  createdAt      DateTime      @default(now()) // 🔥 Add this line
}


model ServiceBooking {
  id           String   @id @default(uuid())
  customerId   String?
  customer     User?    @relation(fields: [customerId], references: [id])
  guestName    String?
  guestPhone   String?
  contactName  String?
  contactPhone String?
  appliance    String
  issue        String
  aiDiagnosis  String?
  status       Status   @default(PENDING)
  scheduledAt  DateTime
  address      String?
  locationLat  Float?
  locationLng  Float?
  finalCost    Float?
  paymentQR    String?
  invoiceUrl   String?
  rating       Int?
  assignment   ServiceAssignment?
  events       ServiceEvent[]
  otps         ServiceOtp[]
  documents    DocumentLog[]
}

model Gallery {
  id        String   @id @default(uuid())
  imageUrl  String
  mediaType String   @default("image")
  caption   String?
  createdAt DateTime @default(now())
}

model Technician {
  id         String              @id @default(uuid())
  name       String
  phone      String              @unique
  role       Role                @default(TECHNICIAN)
  pincode    String
  active     Boolean             @default(true)
  createdAt  DateTime            @default(now())
  assignments ServiceAssignment[]
}

model ServiceAssignment {
  bookingId    String    @id
  technicianId String
  pincode      String?
  routeNote    String?
  assignedAt   DateTime  @default(now())
  booking      ServiceBooking @relation(fields: [bookingId], references: [id])
  technician   Technician     @relation(fields: [technicianId], references: [id])
}

model ServiceEvent {
  id        String   @id @default(uuid())
  bookingId String
  status    String
  note      String?
  createdAt DateTime @default(now())
  booking   ServiceBooking @relation(fields: [bookingId], references: [id])
}

model ServiceOtp {
  id        String   @id @default(uuid())
  bookingId String
  otp       String
  expiresAt DateTime
  verified  Boolean @default(false)
  createdAt DateTime @default(now())
  booking   ServiceBooking @relation(fields: [bookingId], references: [id])
}

model SellRequest {
  id            String            @id @default(uuid())
  userId        String
  applianceType String
  brandModel    String
  conditionNote String
  expectedPrice Float?
  pincode       String?
  imageUrl      String?
  status        SellRequestStatus @default(REQUESTED)
  createdAt     DateTime          @default(now())
  user          User              @relation(fields: [userId], references: [id])
  offers        SellOffer[]
}

model SellOffer {
  id         String           @id @default(uuid())
  requestId  String
  offerPrice Float
  pickupSlot DateTime?
  status     SellOfferStatus  @default(PENDING)
  createdAt  DateTime         @default(now())
  request    SellRequest      @relation(fields: [requestId], references: [id])
}

model DocumentLog {
  id        String   @id @default(uuid())
  docType   String
  bookingId String?
  meta      String?
  createdAt DateTime @default(now())
  booking   ServiceBooking? @relation(fields: [bookingId], references: [id])
}

model ProductOrder {
  id              String        @id @default(uuid())
  productId       String
  customerId      String?
  productTitle    String
  productImageUrl String?
  price           Float
  customerName    String?
  deliveryPhone   String
  deliveryAddress String
  orderStatus     OrderStatus   @default(ORDER_PLACED)
  paymentStatus   PaymentStatus @default(PENDING)
  internalNote    String?
  paymentQR       String?
  invoiceUrl      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  product         Product       @relation(fields: [productId], references: [id])
  customer        User?         @relation(fields: [customerId], references: [id])
}

// Semicolons (;) hata kar space ya new line use karo
enum Role { 
  ADMIN 
  CUSTOMER 
  TECHNICIAN 
}

enum ProductStatus { 
  AVAILABLE 
  SOLD 
}

enum ProductType {
  NEW
  REFURBISHED
}

enum WarrantyType {
  BRAND
  SHOP
}

enum Status { 
  PENDING 
  ASSIGNED
  OUT_FOR_REPAIR
  REPAIRING
  FIXED
  COMPLETED 
  ESTIMATE_APPROVED
  PAYMENT_PENDING
  CANCELLED
}

enum OrderStatus {
  ORDER_PLACED
  DISPATCHED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
}

enum SellRequestStatus {
  REQUESTED
  OFFER_SENT
  ACCEPTED
  REJECTED
  REFURBISHED_LISTED
}

enum SellOfferStatus {
  PENDING
  ACCEPTED
  REJECTED
}
