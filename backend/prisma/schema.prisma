// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  // URL yahan se hata di gayi hai, ye prisma.config.ts mein jayegi
}

model User {
  id                 String   @id @default(uuid())
  name               String
  email              String   @unique
  phone              String?  @unique
  password           String?
  role               Role     @default(CUSTOMER)
  verifyOtp          String?
  verifyOtpExpiryAt  Float?
  isAccountVerified  Boolean  @default(false)
  phoneVerifyOtp     String?
  phoneVerifyOtpExpiryAt Float?
  isPhoneVerified    Boolean  @default(false)
  resetOtp           String?
  resetOtpExpiryAt   Float?
  products           Product[]
  bookings           ServiceBooking[]
  createdAt          DateTime @default(now())
}

model Product {
  id             String        @id @default(uuid())
  title          String
  description    String
  price          Float
  isUsed         Boolean       @default(false)
  productType    ProductType   @default(NEW)
  conditionScore Int?
  ageMonths      Int?
  warrantyType   WarrantyType?
  warrantyExpiry DateTime?
  warrantyCertificateUrl String?
  serialNumber   String?       @unique
  images         String[]
  status         ProductStatus @default(AVAILABLE)
  sellerId       String
  seller         User          @relation(fields: [sellerId], references: [id])
  createdAt      DateTime      @default(now()) // 🔥 Add this line
}


model ServiceBooking {
  id           String   @id @default(uuid())
  customerId   String?
  customer     User?    @relation(fields: [customerId], references: [id])
  guestName    String?
  guestPhone   String?
  contactName  String?
  contactPhone String?
  appliance    String
  issue        String
  aiDiagnosis  String?
  status       Status   @default(PENDING)
  scheduledAt  DateTime
  address      String?
  locationLat  Float?
  locationLng  Float?
  finalCost    Float?
  paymentQR    String?
  invoiceUrl   String?
  rating       Int?
}

model Gallery {
  id        String   @id @default(uuid())
  imageUrl  String
  caption   String?
  createdAt DateTime @default(now())
}

// Semicolons (;) hata kar space ya new line use karo
enum Role { 
  ADMIN 
  CUSTOMER 
  TECHNICIAN 
}

enum ProductStatus { 
  AVAILABLE 
  SOLD 
}

enum ProductType {
  NEW
  REFURBISHED
}

enum WarrantyType {
  BRAND
  SHOP
}

enum Status { 
  PENDING 
  ASSIGNED
  OUT_FOR_REPAIR
  REPAIRING
  FIXED
  COMPLETED 
  ESTIMATE_APPROVED
  PAYMENT_PENDING
  CANCELLED
}
