// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  // URL yahan se hata di gayi hai, ye prisma.config.ts mein jayegi
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String?  
  role      Role     @default(CUSTOMER)
  products  Product[]
  bookings  ServiceBooking[]
  createdAt DateTime @default(now())
}

model Product {
  id             String   @id @default(uuid())
  title          String
  description    String
  price          Float
  isUsed         Boolean  @default(false)
  conditionScore Int?
  images         String[]
  status         ProductStatus @default(AVAILABLE)
  sellerId       String
  seller         User     @relation(fields: [sellerId], references: [id])
}

model ServiceBooking {
  id           String   @id @default(uuid())
  customerId   String
  customer     User     @relation(fields: [customerId], references: [id])
  appliance    String
  issue        String
  aiDiagnosis  String?
  status       Status   @default(PENDING)
  scheduledAt  DateTime
}

// Semicolons (;) hata kar space ya new line use karo
enum Role { 
  ADMIN 
  CUSTOMER 
  TECHNICIAN 
}

enum ProductStatus { 
  AVAILABLE 
  SOLD 
}

enum Status { 
  PENDING 
  IN_PROGRESS 
  COMPLETED 
  CANCELLED 
}
